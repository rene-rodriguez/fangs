;; Fangs terminal configuration
;; Place this file at ~/.config/fangs/config
;;
;; The API key is read from $FANGS_API_KEY by default (recommended).
;; Only put it in this file as a fallback — the file is chmod 0600
;; on write, but env vars are still harder to accidentally commit.
;;
;; Command-palette runbooks live next to this file at:
;;   ~/.config/fangs/workflows
;; Project-local runbooks can also live at:
;;   .fangs/workflows
;; Runbook variables use {{name}} or {{name=default}}.

[terminal]
font_family = JetBrainsMono Nerd Font
font_size = 16
theme = dark
scrollback = 1000
kitty_images = true
kitty_image_storage_mb = 64
cursor_style = 0      ;; 0=block, 1=bar, 2=underline
cursor_blink = true

[ui]
workspace_rail = true  ;; left-side tabs, panes, and notification rings

[window]
width = 800
height = 600
x = -1                ;; -1 means let macOS/Linux place the window
y = -1

[remote]
;; WARNING: remote_api_send enables arbitrary command execution via
;; 'send' and 'new --run' — same trust model as tmux send-keys.
remote_api = false       ;; enable Unix-socket JSON API (read-only)
remote_api_send = false  ;; additionally enable send and new --run

[workspace]
;; Typed + Entered into a worktree workspace's shell right after you create
;; one (palette action, Option/Alt-click +, or the row context menu). Only
;; fires for interactive creation, not `fangs ctl new --worktree` (which has
;; its own explicit --run). Empty disables it.
workspace_command =
;; Reopen the workspaces (cwd + name) that were open last time, on launch.
restore_session = true

[ai]
provider = openai     ;; "openai" (OpenAI-compatible) or "anthropic"
endpoint = https://api.openai.com/v1/chat/completions
model = gpt-4o-mini
api_key =             ;; prefer $FANGS_API_KEY over this field
stream = true
max_tokens = 1024
